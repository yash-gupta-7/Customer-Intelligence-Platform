# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=customer-intelligence-platform
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# ─── API Security ────────────────────────────────────────────────────────────
API_SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=customer-conversion
MODEL_REGISTRY_NAME=conversion-model
MODEL_STAGE=Production

# ─── ML Model ────────────────────────────────────────────────────────────────
MODEL_PATH=models/conversion_model.pkl
FEATURES_PATH=data/processed/features.parquet
REFERENCE_DATA_PATH=data/processed/reference.parquet
PROMOTION_AUC_GATE=0.75

# ─── RAG ─────────────────────────────────────────────────────────────────────
COMPLAINTS_DATA_PATH=data/complaints/complaints.csv
FAISS_INDEX_PATH=models/faiss_index
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ─── LLM (optional — set for cloud LLM, leave blank for local mode) ─────────
OPENAI_API_KEY=
LLM_PROVIDER=local
LLM_MODEL=gpt-3.5-turbo

# ─── Monitoring ──────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
DRIFT_REPORT_PATH=reports/drift

# ─── Docker ──────────────────────────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest
